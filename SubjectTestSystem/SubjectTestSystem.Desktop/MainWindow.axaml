<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SubjectTestSystem.Desktop.ViewModels"
        xmlns:models="using:SubjectTestSystem.Shared.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="using:SubjectTestSystem.Desktop.Converters"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="SubjectTestSystem.Desktop.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="學科檢定模擬系統"
        Icon="/Assets/icon.jpg">

    <Window.Resources>
        <conv:ReviewOptionColorConverter x:Key="ReviewColorConverter"/>
        <conv:ReviewOptionForegroundConverter x:Key="ReviewForegroundConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="20" RowDefinitions="Auto, *">
        <!-- Error Bar -->
        <Border Grid.Row="0" Background="#F44336" CornerRadius="5" Margin="0,0,0,10" Padding="10"
                IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <!-- Main Content Area -->
        <Panel Grid.Row="1">
            <!-- Home View -->
            <StackPanel IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:AppState.Home}}"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <TextBlock Text="電腦軟體設計丙級 - 學科模擬測驗" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="包含：專業科目(60題) + 共同科目(20題)" FontSize="16" 
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" 
                           HorizontalAlignment="Center"/>
                <Button Content="開始測驗" Command="{Binding StartTestCommand}" 
                        Padding="30,15" Background="{DynamicResource SystemAccentColor}" Foreground="White" FontSize="20" CornerRadius="5"/>
            </StackPanel>

            <!-- Testing View -->
            <Grid IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:AppState.Testing}}"
                  RowDefinitions="Auto, *, Auto" ColumnDefinitions="200, *">
                
                <!-- Header -->
                <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnDefinitions="*, Auto, Auto" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentQuestion.OriginalQuestion.WorkItem}" FontSize="14" 
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock FontSize="18" FontWeight="SemiBold">
                            <Run Text="第"/>
                            <Run Text="{Binding CurrentQuestionIndex, Converter={StaticResource IndexToDisplayConverter}}"/>
                            <Run Text="題 / 共"/>
                            <Run Text="{Binding TestItems.Count}"/>
                            <Run Text="題"/>
                        </TextBlock>
                    </StackPanel>
                    <CheckBox Grid.Column="1" Content="標記此題" IsChecked="{Binding CurrentQuestion.IsMarked}" 
                              VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#FF9800"/>
                    <Button Grid.Column="2" Content="交卷" Command="{Binding RequestSubmitCommand}" 
                            Background="#F44336" Foreground="White" VerticalAlignment="Center"/>
                </Grid>

                <!-- Navigation Sidebar (Testing) -->
                <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,1,0" Padding="0,0,10,0">
                    <ListBox ItemsSource="{Binding TestItems}" 
                             SelectedIndex="{Binding CurrentQuestionIndex, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:TestItem">
                                <Border Padding="5">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).TestItems, Converter={StaticResource IndexToDisplayConverter}, ConverterParameter={Binding}}"
                                                   Width="30" VerticalAlignment="Center"/>
                                        <Panel VerticalAlignment="Center">
                                            <!-- Answered Status -->
                                            <TextBlock Text="✅" IsVisible="{Binding IsAnswered}" Foreground="#2E7D32"/>
                                            <TextBlock Text="⚪" IsVisible="{Binding !IsAnswered}" Foreground="#9E9E9E"/>
                                        </Panel>
                                        <!-- Mark Status -->
                                        <TextBlock Text="🚩" IsVisible="{Binding IsMarked}" Foreground="#FF9800" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="2"/>
                            </Style>
                        </ListBox.Styles>
                    </ListBox>
                </Border>

                <!-- Question Area -->
                <ScrollViewer Grid.Row="1" Grid.Column="1" Padding="20,0,0,0" DataContext="{Binding CurrentQuestion}">
                    <StackPanel Spacing="20" IsVisible="{Binding $self.DataContext, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <TextBlock Text="{Binding OriginalQuestion.Question}" FontSize="20" TextWrapping="Wrap"/>
                        
                        <ListBox ItemsSource="{Binding ShuffledOptions}"
                                 SelectedIndex="{Binding SelectedOptionIndex, Mode=TwoWay}"
                                 Background="Transparent">

                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:OptionItem">
                                    <RadioButton Margin="0,5"
                                                 IsChecked="{Binding $parent[ListBoxItem].IsSelected, Mode=TwoWay}"
                                                 Content="{Binding Text}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="10,5"/>
                                </Style>
                            </ListBox.Styles>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- Navigation -->
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,20,0,0">
                    <Button Content="上一題" Command="{Binding GoPreviousCommand}" Width="100" HorizontalContentAlignment="Center"/>
                    <Button Content="下一題" Command="{Binding GoNextCommand}" Width="100" HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Submit Confirmation Overlay -->
            <Border IsVisible="{Binding ShowSubmitConfirmation}" Background="#80000000" Grid.RowSpan="2">
                <Border Background="{DynamicResource SystemAltHighColor}" HorizontalAlignment="Center" VerticalAlignment="Center" 
                        Padding="30" CornerRadius="10" BoxShadow="0 5 15 0 #40000000">
                    <StackPanel Spacing="20" Width="300">
                        <TextBlock Text="確認交卷" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                        
                        <Border Background="#FFF3E0" Padding="15" CornerRadius="5" 
                                IsVisible="{Binding !!UnansweredCount}">
                            <TextBlock Foreground="#E65100" TextWrapping="Wrap" HorizontalAlignment="Center">
                                <Run Text="⚠ 您還有 "/>
                                <Run Text="{Binding UnansweredCount}" FontWeight="Bold"/>
                                <Run Text=" 題尚未回答。"/>
                            </TextBlock>
                        </Border>

                        <Border Background="#E1F5FE" Padding="15" CornerRadius="5" 
                                IsVisible="{Binding !!MarkedCount}">
                            <TextBlock Foreground="#0277BD" TextWrapping="Wrap" HorizontalAlignment="Center">
                                <Run Text="ℹ 您標記了 "/>
                                <Run Text="{Binding MarkedCount}" FontWeight="Bold"/>
                                <Run Text=" 題供後續檢查。"/>
                            </TextBlock>
                        </Border>

                        <TextBlock Text="確定要交卷並計算分數嗎？" HorizontalAlignment="Center"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
                            <Button Content="繼續作答" Command="{Binding CancelSubmitCommand}" Padding="20,10"/>
                            <Button Content="確認交卷" Command="{Binding ConfirmSubmitCommand}" 
                                    Padding="20,10" Background="#F44336" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Review View -->
            <Grid IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:AppState.Review}}"
                  RowDefinitions="Auto, *, Auto" ColumnDefinitions="200, *">
                
                <!-- Header -->
                <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="題目回顧模式" FontSize="14" Foreground="#FF9800" FontWeight="Bold"/>
                        <TextBlock FontSize="18" FontWeight="SemiBold">
                            <Run Text="第"/>
                            <Run Text="{Binding CurrentQuestionIndex, Converter={StaticResource IndexToDisplayConverter}}"/>
                            <Run Text="題 / 共"/>
                            <Run Text="{Binding TestItems.Count}"/>
                            <Run Text="題"/>
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Content="結束回顧" Command="{Binding BackToHomeCommand}" 
                            Background="{DynamicResource SystemControlForegroundBaseMediumBrush}" Foreground="White" VerticalAlignment="Center"/>
                </Grid>

                <!-- Navigation Sidebar -->
                <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" 
                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,1,0" Padding="0,0,10,0">
                    <ListBox ItemsSource="{Binding TestItems}" 
                             SelectedIndex="{Binding CurrentQuestionIndex, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:TestItem">
                                <Border Padding="5">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding $parent[ListBox].((vm:MainViewModel)DataContext).TestItems, Converter={StaticResource IndexToDisplayConverter}, ConverterParameter={Binding}}"
                                                   Width="30" VerticalAlignment="Center"/>
                                        <Panel VerticalAlignment="Center">
                                            <TextBlock Text="✅" IsVisible="{Binding IsCorrect}" Foreground="#2E7D32"/>
                                            
                                            <!-- Logic for Incorrect: IsAnswered=True AND IsCorrect=False -->
                                            <TextBlock Text="❌" Foreground="#C62828">
                                                <TextBlock.IsVisible>
                                                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                                                        <Binding Path="IsAnswered" />
                                                        <Binding Path="IsCorrect" Converter="{StaticResource BoolToVis}" ConverterParameter="invert" />
                                                    </MultiBinding>
                                                </TextBlock.IsVisible>
                                            </TextBlock>
                                            
                                            <!-- Logic for Unanswered: IsAnswered=False -->
                                            <TextBlock Text="⚪" IsVisible="{Binding IsAnswered, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" Foreground="#9E9E9E"/>
                                        </Panel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="2"/>
                            </Style>
                        </ListBox.Styles>
                    </ListBox>
                </Border>

                <!-- Question Area -->
                <ScrollViewer Grid.Row="1" Grid.Column="1" Padding="20,0,0,0">
                    <StackPanel Spacing="20">
                        <TextBlock Text="{Binding CurrentQuestion.OriginalQuestion.Question}" FontSize="20" TextWrapping="Wrap"/>
                        
                        <ItemsControl ItemsSource="{Binding CurrentQuestion.ShuffledOptions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:OptionItem">
                                    <Border Margin="0,5" Padding="15,10" CornerRadius="5">
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource ReviewColorConverter}">
                                                <Binding Path="." />
                                                <Binding Path="$parent[ItemsControl].DataContext" />
                                            </MultiBinding>
                                        </Border.Background>
                                        <TextBlock Text="{Binding Text}" VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <MultiBinding Converter="{StaticResource ReviewForegroundConverter}">
                                                    <Binding Path="." />
                                                    <Binding Path="$parent[ItemsControl].DataContext" />
                                                </MultiBinding>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Correct/Wrong summary for this question -->
                        <Border Padding="15" CornerRadius="8" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="✅ 這題答對了！" IsVisible="{Binding CurrentQuestion.IsCorrect}" Foreground="#2E7D32" FontWeight="Bold" FontSize="18"/>
                                
                                <TextBlock Text="❌ 這題答錯了。" Foreground="#C62828" FontWeight="Bold" FontSize="18">
                                    <TextBlock.IsVisible>
                                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                                            <Binding Path="CurrentQuestion.IsAnswered" />
                                            <Binding Path="CurrentQuestion.IsCorrect" Converter="{StaticResource BoolToVis}" ConverterParameter="invert" />
                                        </MultiBinding>
                                    </TextBlock.IsVisible>
                                </TextBlock>
                                
                                <TextBlock Text="⚪ 您沒有回答這題。" IsVisible="{Binding CurrentQuestion.IsAnswered, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" Foreground="#9E9E9E" FontWeight="Bold" FontSize="18"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Navigation -->
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,20,0,0">
                    <Button Content="上一題" Command="{Binding GoPreviousCommand}" Width="100" HorizontalContentAlignment="Center"/>
                    <Button Content="下一題" Command="{Binding GoNextCommand}" Width="100" HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Result View -->
            <StackPanel IsVisible="{Binding CurrentState, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static vm:AppState.Result}}"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <TextBlock Text="測驗結束" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Score, StringFormat='您的得分：{0:F1} 分'}" FontSize="24" 
                           Foreground="#4CAF50" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="及格標準：60 分" FontSize="16" HorizontalAlignment="Center"/>
                
                <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
                    <Button Content="查看題目" Command="{Binding ReviewTestCommand}" 
                            Padding="20,10" CornerRadius="5" Background="#2196F3" Foreground="White"/>
                    <Button Content="回到首頁" Command="{Binding BackToHomeCommand}" 
                            Padding="20,10" CornerRadius="5"/>
                </StackPanel>
            </StackPanel>
        </Panel>
    </Grid>
</Window>
